{
  "manifest_version": 3,
  "name": "Formula Copy",
  "version": "1.0.0",
  "description": "Copy KaTeX-rendered math formulas from ChatGPT as clean LaTeX source code",
  "permissions": [
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
