{
  "manifest_version": 3,
  "name": "Formula Copy",
  "version": "1.0.0",
  "description": "Copy KaTeX-rendered math formulas from ChatGPT as clean LaTeX source code",
  "permissions": [
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-inactive.svg",
      "48": "icons/icon-inactive.svg",
      "128": "icons/icon-inactive.svg"
    },
    "default_title": "Formula Copy"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon-active.svg",
    "48": "icons/icon-active.svg",
    "128": "icons/icon-active.svg"
  }
}
